// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prompt {
  id            String   @id @default(cuid())
  title         String
  description   String
  body          String   @db.Text
  fieldsSchema  Json
  category      String
  tags          String[]
  sampleImage   String?
  isPremium     Boolean  @default(false)
  isActive      Boolean  @default(true)
  usageCount    Int      @default(0)
  
  // Forking/Anshab relations
  parentId      String?
  sourceText    String?  @db.Text
  parent        Prompt?  @relation("PromptToPrompt", fields: [parentId], references: [id])
  children      Prompt[] @relation("PromptToPrompt")

  forkedFromId  String?
  forkedFrom    Prompt?  @relation("PromptForks", fields: [forkedFromId], references: [id])
  forks         Prompt[] @relation("PromptForks")
  savedBy       SavedPrompt[]
  presets       PromptPreset[]

  // Smart Media Engine
  coverImage    String?
  mediaGallery  Json?
  
  // AI Metadata Layers (Dynamic Validation)
  intent        String?
  domains       String[]
  tools         String[]
  task          String?
  language      String?
  difficulty    String?
  outputFormats String[]
  industry      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Taxonomy {
  id            String   @id @default(cuid())
  type          String   // INTENT, DOMAIN, TOOL, LANGUAGE, DIFFICULTY, OUTPUT_FORMAT, INDUSTRY
  slug          String   @unique
  titleEn       String
  titleFa       String
  descriptionFa String?
  descriptionEn String?
  aliases       String[]
  synonyms      String[]
  popularity    Float    @default(0.5)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  phone        String?       @unique
  name         String?
  avatar       String?
  role         Role          @default(USER)
  savedPrompts SavedPrompt[]
  presets      PromptPreset[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SavedPrompt {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, promptId])
}

model PromptPreset {
  id        String   @id @default(uuid())
  name      String   // نام نسخه مثلا: کاور آموزشی
  values    Json     // مقادیر فیلدها (key-value)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

